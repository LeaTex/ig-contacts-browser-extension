{
  "manifest_version": 3,
  "name": "IG Contacts",
  "version": "1.0.0",
  "description": "Instagram contacts manager",
  
  "permissions": [
    "activeTab",
    "scripting",
    "cookies",
    "storage"
  ],
  
  "host_permissions": [
    "*://www.instagram.com/*",
    "*://instagram.com/*",
    "*://*.fna.fbcdn.net/*"
  ],
  
  "background": {
    "service_worker": "background.js",
    "scripts": ["background.js"]
  },
  
  "content_scripts": [
    {
      "matches": ["*://www.instagram.com/*", "*://instagram.com/*"],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ],
  
  "action": {
    "default_popup": "popup.html",
    "default_title": "IG Contacts"
  },
  
  "icons": {
    "32": "contacts-32.png",
    "48": "contacts-48.png",
    "96": "contacts-96.png"
  }
}
